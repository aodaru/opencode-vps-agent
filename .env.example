# OpenCode VPS - Environment Variables Template
# Copia este archivo a .env y rellena con tus valores reales.
# .env esta en .gitignore y NO se sube al repositorio.

# ------------------------------------------------------------
# NOTA: Los usuarios 'devadmin' y 'cloud' dentro del contenedor
# se crean con password 'changeme' (ver Dockerfile:54-59).
# Esos passwords NO viven en este archivo: cambiar manualmente
# despues del primer arranque con:
#   docker compose exec -it opencode-vps passwd devadmin
#   docker compose exec -it opencode-vps passwd cloud
# ------------------------------------------------------------

# Autenticacion web de OpenCode (HTTP Basic Auth)
OPENCODE_SERVER_PASSWORD=change-me-strong-password

# Cloudflare Tunnel Token (https://one.dash.cloudflare.com)
CLOUDFLARE_TUNNEL_TOKEN=eyJh...your-token-here

# OpenCode Go API key (https://opencode.ai/auth)
# OPCIONAL: backup. La fuente de verdad es ./data/opencode-auth/auth.json
# (se crea con `opencode auth login --provider opencode-go` dentro del contenedor).
OPENCODE_API_KEY=sk-your-api-key-here

# GH Token GitHub Token
GH_TOKEN=github...your-token-here

# Passwords de usuarios del contenedor (SSH).
# Se aplican automaticamente al arrancar via supervisor (set-passwords).
# Si se dejan vacias o se omiten, los usuarios quedan con password aleatorio
# generado en el build.
DEVADMIN_PASSWORD=changeme
CLOUD_PASSWORD=changeme
